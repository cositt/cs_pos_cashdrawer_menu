<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="cs_pos_cashdrawer_menu.ControlButtons"
       t-inherit="point_of_sale.ControlButtons"
       t-inherit-mode="extension">
        <xpath expr="//div[hasclass('control-buttons-modal')]/button[hasclass('o_pricelist_button')]" position="before">
            <button t-if="pos.config.iface_cashdrawer" t-att-class="buttonClass" t-on-click="() => this.pos.hardwareProxy.openCashbox('Abrir caja')">
                <i class="fa fa-archive me-2" />
                Abrir caja
            </button>
        </xpath>
    </t>

    <t t-name="cs_pos_cashdrawer_menu.PaymentScreenButtons"
       t-inherit="point_of_sale.PaymentScreenButtons"
       t-inherit-mode="extension">
        <xpath expr="//button[hasclass('js_cashdrawer')]" position="attributes">
            <attribute name="t-if">false</attribute>
        </xpath>
    </t>

</templates>
